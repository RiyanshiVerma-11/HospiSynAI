# PostgreSQL Database Configuration
POSTGRES_DB=hospisyn
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_PORT=5432

# Backend API Configuration
# Note: Use 'db' as the host inside docker-compose (e.g., postgresql://postgres:postgrespassword@db:5432/hospisyn)
# Or use 'localhost' if running the backend outside Docker (e.g., postgresql://postgres:postgrespassword@localhost:5432/hospisyn)
DATABASE_URL=postgresql://postgres:postgrespassword@db:5432/hospisyn
JWT_SECRET=supersecretgooglesde3hospitalbillingsystemkey12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
BACKEND_PORT=5000

# Frontend Configuration
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:5000/api
VITE_STATIC_BASE_URL=http://localhost:5000

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

